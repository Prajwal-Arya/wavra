POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=music
POSTGRES_PASSWORD=music
POSTGRES_DB=music_player
JWT_SECRET=change-me
API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api
YTDLP_PATH=/home/qnuuser/.local/bin/yt-dlp
FFMPEG_PATH=/usr/bin/ffmpeg

# ── Cloudflare R2 (leave blank to fall back to local disk storage) ──────────
# Cloudflare Dashboard → R2 → Manage API Tokens → Create Token (Object Read & Write)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=soundnest-media
# Optional: public bucket URL (enables direct browser downloads without pre-signed URLs)
R2_PUBLIC_URL=

# Public base URL of this API server (used by local storage to generate file URLs)
API_BASE_URL=http://localhost:3001
